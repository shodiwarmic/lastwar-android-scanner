<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_app"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnStartService"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_start_scanning"
        android:padding="12dp"/>

    <Button
        android:id="@+id/btnStopService"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_stop_scanning"
        android:layout_marginTop="8dp"
        android:visibility="gone"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/btnExportCsv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/btn_export_csv"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnClearLogs"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/btn_clear_history"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="@color/clear_history_red"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/status_idle"
        android:textAlignment="center"
        android:textStyle="bold"/>

    <ProgressBar
        android:id="@+id/pbScanning"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:visibility="invisible"
        android:indeterminate="true"/>

    <TextView
        android:id="@+id/tvDetectedDay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/active_tab_unknown"
        android:textAlignment="center"
        android:textColor="@color/active_tab_blue"
        android:layout_marginTop="4dp"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="8dp">
                <TextView
                    android:id="@+id/headerPlayer"
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:text="@string/header_member"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground"/>
                <TextView
                    android:id="@+id/headerMon"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/header_mon"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textAlignment="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground"/>
                <TextView
                    android:id="@+id/headerTues"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/header_tues"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textAlignment="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground"/>
                <TextView
                    android:id="@+id/headerWed"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/header_wed"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textAlignment="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground"/>
                <TextView
                    android:id="@+id/headerThur"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/header_thur"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textAlignment="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground"/>
                <TextView
                    android:id="@+id/headerFri"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/header_fri"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textAlignment="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground"/>
                <TextView
                    android:id="@+id/headerSat"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/header_sat"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textAlignment="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground"/>
                <TextView
                    android:id="@+id/headerPower"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="@string/header_power"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textAlignment="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground"/>
                <TextView
                    android:id="@+id/headerKills"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="@string/header_kills"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textAlignment="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground"/>
                <TextView
                    android:id="@+id/headerDonation"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="@string/header_donation"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textAlignment="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/header_divider"
                android:layout_marginBottom="4dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvScores"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:scrollbars="vertical"/>
        </LinearLayout>
    </HorizontalScrollView>

</LinearLayout>